# Database（默认使用项目根目录 data/nameface.db，无需修改）
# DATABASE_URL=

# Face recognition — balanced long-range (buffalo_l @ 960, ~30ms GPU)
FACE_MODEL_NAME=buffalo_l
FACE_DET_SIZE=960
FACE_DET_THRESH=0.3
FACE_MIN_IMAGE_SIZE=720
FACE_MAX_IMAGE_SIZE=1280
FACE_MATCH_THRESHOLD=0.45

# LLM: AI 助手（留空则禁用）
LLM_PROVIDER=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai-next.com

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 通义千问
DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=qwen-plus

# Ollama (local GPU)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
