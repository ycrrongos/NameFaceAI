# Database
DATABASE_URL=sqlite:///data/nameface.db

# Face recognition — classroom mode (distant / multi-face)
# buffalo_l: SCRFD-10G detector, best for small/distant faces in classroom
# buffalo_m: SCRFD-2.5G, lighter but weaker at distance
# buffalo_sc: SCRFD-500M, CPU-only fallback (close range only)
FACE_MODEL_NAME=buffalo_l
FACE_DET_SIZE=640
FACE_DET_THRESH=0.4
FACE_MAX_IMAGE_SIZE=1280
FACE_MATCH_THRESHOLD=0.45

# LLM provider: dashscope | deepseek | ollama | (empty = disabled)
LLM_PROVIDER=

# 通义千问 (DashScope)
DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=qwen-plus

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Ollama (local GPU)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
