# Database（默认使用项目根目录 data/nameface.db，无需修改）
# DATABASE_URL=

# Face recognition — classroom mode (distant / multi-face)
FACE_MODEL_NAME=buffalo_l
FACE_DET_SIZE=640
FACE_DET_THRESH=0.4
FACE_MAX_IMAGE_SIZE=1280
FACE_MATCH_THRESHOLD=0.45

# Mac Apple Silicon: CoreML is tried automatically (requires onnxruntime with CoreML EP).
# For GPU classroom tuning you may use FACE_DET_SIZE=960, FACE_DET_THRESH=0.35, FACE_MIN_IMAGE_SIZE=720

# LLM: AI 助手
LLM_PROVIDER=openai

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai-next.com

# DeepSeek (optional)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 通义千问 (optional)
DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=qwen-plus

# Ollama (optional, local GPU)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
