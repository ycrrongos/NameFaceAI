# Database
DATABASE_URL=sqlite:///data/nameface.db

# Face recognition
FACE_MATCH_THRESHOLD=0.45

# LLM provider: dashscope | deepseek | ollama | (empty = disabled)
LLM_PROVIDER=

# 通义千问 (DashScope)
DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=qwen-plus

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Ollama (local GPU)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
