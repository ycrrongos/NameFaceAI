# Database
DATABASE_URL=sqlite:///data/nameface.db

# Face recognition presets
# buffalo_l @ 960: SCRFD-10G + ResNet50, ~30ms GPU, good for classroom distance (default)
# antelopev2 @ 1280: SCRFD-10G + GlintR100, ~60ms GPU, best accuracy
# buffalo_sc @ 320: CPU / close range only
FACE_MODEL_NAME=buffalo_l
FACE_DET_SIZE=960
FACE_DET_THRESH=0.35
FACE_MIN_IMAGE_SIZE=720

# Mac Apple Silicon: CoreML is tried automatically (requires onnxruntime with CoreML EP).
# Note: buffalo_l may still run on CPU if CoreML cannot compile its ONNX ops.
# For Mac-only tuning you may use FACE_DET_SIZE=640 and FACE_DET_THRESH=0.4 instead.
FACE_MAX_IMAGE_SIZE=1280
FACE_MATCH_THRESHOLD=0.45

# LLM provider: dashscope | deepseek | openai | ollama | (empty = disabled)
LLM_PROVIDER=

# 通义千问 (DashScope)
DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=qwen-plus

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com

# Ollama (local GPU)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
